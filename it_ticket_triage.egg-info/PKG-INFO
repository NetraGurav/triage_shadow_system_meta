├── inference.py          # Baseline evaluation pipeline (main entry point)
├── app.py                # FastAPI + Gradio server
├── train.py              # SFT model training script
├── requirements.txt
├── Dockerfile
├── pyproject.toml
│
├── data/
│   ├── __init__.py
│   └── tickets.py        # 24 curated IT tickets (8 easy, 8 medium, 8 hard)
│
├── env/
│   ├── __init__.py
│   ├── environment.py    # OpenEnv core: reset(), step(), state() + Shadow RL
│   ├── features.py       # Observation builder (TF-IDF + keyword signals)
│   ├── graders.py        # Task graders: EasyGrader, MediumGrader, HardGrader
│   └── models.py         # Pydantic typed models (Observation, Action, Reward)
│
├── model/
│   ├── __init__.py
│   ├── sft_model.py      # TF-IDF + Logistic Regression SFT baseline
│   ├── llm_agent.py      # Multi-backend LLM agent (Groq, Gemini, OpenAI)
│   └── schema.py         # Pydantic schema for LLM structured output
│
└── server/
    ├── __init__.py
    └── app.py            # Uvicorn entry point
```

